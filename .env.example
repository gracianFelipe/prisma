# ESUP News — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas chaves.

# --- API keys ---
NEWSDATA_API_KEY=
THENEWSAPI_API_KEY=

# --- Banco ---
DATABASE_PATH=data/esup_news.db

# --- Coleta e classificação ---
SCORE_CUTOFF=6
INCREMENTAL_WINDOW_HOURS=12
WEEKLY_WINDOW_HOURS=168
DEFAULT_LIMIT_PER_QUERY=10

# --- HTTP ---
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=3

# --- Curadoria ---
CURATOR_NAME=admin

# --- Tempo ---
LOCAL_TZ=America/Sao_Paulo
